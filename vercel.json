{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.janco.tech"
        }
      ],
      "destination": "https://janco.tech/:path*",
      "permanent": true
    }
  ]
}
