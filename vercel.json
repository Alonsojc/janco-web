{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/sistemas/arrendamiento-puro",
      "destination": "/sistemas/arrendamiento-puro.html"
    },
    {
      "source": "/sistemas/panaderia",
      "destination": "/sistemas/panaderia.html"
    },
    {
      "source": "/sistemas/restaurante",
      "destination": "/sistemas/restaurante.html"
    },
    {
      "source": "/sistemas/bordadoras",
      "destination": "/sistemas/bordadoras.html"
    },
    {
      "source": "/sistemas/a-medida",
      "destination": "/sistemas/a-medida.html"
    },
    {
      "source": "/recursos/sistema-arrendamiento-puro-cobranza-arrendadoras",
      "destination": "/recursos/sistema-arrendamiento-puro-cobranza-arrendadoras.html"
    },
    {
      "source": "/recursos/sistema-arrendamiento-puro",
      "destination": "/recursos/sistema-arrendamiento-puro.html"
    },
    {
      "source": "/recursos/software-cobranza-arrendadoras-mexico",
      "destination": "/recursos/software-cobranza-arrendadoras-mexico.html"
    },
    {
      "source": "/recursos/software-arrendamiento-puro",
      "destination": "/recursos/software-arrendadoras-financieras.html"
    },
    {
      "source": "/recursos/sistema-panaderia-recetas-inventario",
      "destination": "/recursos/sistema-panaderia-recetas-inventario.html"
    },
    {
      "source": "/recursos/software-poke-bar",
      "destination": "/recursos/software-poke-bar.html"
    },
    {
      "source": "/recursos/sistema-taller-bordado",
      "destination": "/recursos/sistema-taller-bordado.html"
    },
    {
      "source": "/privacidad",
      "destination": "/privacidad.html"
    },
    {
      "source": "/marca",
      "destination": "/marca.html"
    }
  ],
  "redirects": [
    {
      "source": "/recursos/software-arrendadoras-financieras",
      "destination": "/recursos/software-arrendamiento-puro",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.janco.tech"
        }
      ],
      "destination": "https://janco.tech/:path*",
      "permanent": true
    }
  ]
}
